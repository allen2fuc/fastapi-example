<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <title>登录</title>
  <link rel="stylesheet" href="/static/css/admin.css">
</head>
<body class="login-body">
<div class="login-card">
  <h2 class="login-title">管理系统</h2>

  {% if error %}
  <div class="login-error">{{ error }}</div>
  {% endif %}

  <form method="post" action="/auth/login" class="login-form">
    <div class="form-item">
      <label for="email">邮箱</label>
      <input type="email" id="email" name="email" required autofocus
             placeholder="请输入邮箱">
    </div>
    <div class="form-item">
      <label for="password">密码</label>
      <input type="password" id="password" name="password" required
             placeholder="请输入密码">
    </div>
    <div class="form-item">
      <label for="captcha_input">验证码</label>
      <div class="captcha-row">
        <input type="text" id="captcha_input" name="captcha_input" required
               placeholder="请输入验证码" maxlength="5" autocomplete="off">
        <img id="captcha-img" src="/auth/captcha" alt="验证码"
             class="captcha-img" onclick="refreshCaptcha()" title="点击刷新">
      </div>
    </div>
    <button type="submit" class="btn-login">登 录</button>
  </form>
</div>

<script>
function refreshCaptcha() {
  document.getElementById('captcha-img').src = '/auth/captcha?t=' + Date.now();
}
</script>
</body>
</html>
